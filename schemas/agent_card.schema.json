{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgriAgentMesh Agent Card",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "role",
    "capabilities"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "runs_on": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "description": {
      "type": "string"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "auth_scopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requires_human_approval": {
      "type": "boolean"
    }
  }
}